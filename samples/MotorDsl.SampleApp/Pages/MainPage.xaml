<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MotorDsl.SampleApp.Controls"
             x:Class="MotorDsl.SampleApp.Pages.MainPage"
             Title="MotorDsl - Ticket Térmico">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">

            <!-- Título -->
            <Label Text="MotorDsl — Impresora Térmica"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,10,0,20"/>

            <!-- Estado de conexión -->
            <Frame BorderColor="Gray"
                   HasShadow="True"
                   CornerRadius="8"
                   Padding="15"
                   Margin="0,0,0,10">
                <HorizontalStackLayout Spacing="10">
                    <Label Text="Estado:"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           FontSize="16"/>
                    <Label x:Name="StatusLabel"
                           Text="Desconectado"
                           TextColor="Red"
                           VerticalOptions="Center"
                           FontSize="16"/>
                </HorizontalStackLayout>
            </Frame>

            <!-- Sección 1: Buscar dispositivos -->
            <Label Text="1. Buscar Dispositivos"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,15,0,10"/>

            <Button x:Name="ScanButton"
                    Text="Escanear Dispositivos Bluetooth"
                    Clicked="OnScanClicked"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50"/>

            <CollectionView x:Name="DeviceList"
                            SelectionMode="Single"
                            SelectionChanged="OnDeviceSelected"
                            HeightRequest="120"
                            IsVisible="False">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding .}"
                               Padding="10,8"
                               FontSize="14"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Sección 2: Conectar -->
            <Label Text="2. Conectar"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,20,0,10"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button x:Name="ConnectButton"
                        Grid.Column="0"
                        Text="Conectar"
                        Clicked="OnConnectClicked"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        IsEnabled="False"
                        CornerRadius="8"
                        HeightRequest="50"/>

                <Button x:Name="DisconnectButton"
                        Grid.Column="1"
                        Text="Desconectar"
                        Clicked="OnDisconnectClicked"
                        BackgroundColor="#F44336"
                        TextColor="White"
                        IsEnabled="False"
                        CornerRadius="8"
                        HeightRequest="50"/>
            </Grid>

            <!-- Sección 3: Motor DSL -->
            <Label Text="3. Ticket DSL"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,20,0,10"/>

            <Button x:Name="PreviewButton"
                    Text="Vista Previa (texto)"
                    Clicked="OnPreviewClicked"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50"
                    Margin="0,5"/>

            <Button x:Name="HexDumpButton"
                    Text="Ver ESC/POS (hex)"
                    Clicked="OnHexDumpClicked"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50"
                    Margin="0,5"/>

            <Button x:Name="PrintButton"
                    Text="Imprimir Ticket"
                    Clicked="OnPrintClicked"
                    BackgroundColor="#FF9800"
                    TextColor="White"
                    IsEnabled="False"
                    CornerRadius="8"
                    HeightRequest="50"
                    Margin="0,5"/>

            <Button x:Name="MauiPreviewButton"
                    Text="Vista Previa (MAUI)"
                    Clicked="OnMauiPreviewClicked"
                    BackgroundColor="#9C27B0"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50"
                    Margin="0,5"/>

            <!-- Sección: Vista Previa MAUI -->
            <Label Text="Vista Previa MAUI"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,20,0,10"/>

            <Frame x:Name="MauiPreviewFrame"
                   BorderColor="DarkGray"
                   CornerRadius="5"
                   Padding="10"
                   HasShadow="False"
                   BackgroundColor="White"
                   IsVisible="False"
                   MinimumHeightRequest="150">
                <ScrollView>
                    <controls:MauiDocumentPreview x:Name="MauiPreview" />
                </ScrollView>
            </Frame>

            <!-- Sección 4: Output preview -->
            <Label Text="4. Output"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,20,0,10"/>

            <Frame BorderColor="LightGray"
                   CornerRadius="5"
                   Padding="10"
                   HasShadow="False"
                   MinimumHeightRequest="200">
                <ScrollView>
                    <Label x:Name="OutputLabel"
                           Text="Esperando acción..."
                           FontSize="12"
                           FontFamily="Consolas"
                           LineBreakMode="WordWrap"/>
                </ScrollView>
            </Frame>

            <!-- Mensaje de estado -->
            <Frame BorderColor="LightGray"
                   CornerRadius="5"
                   Padding="10"
                   Margin="0,15,0,20"
                   HasShadow="False">
                <Label x:Name="MessageLabel"
                       Text="Esperando acción..."
                       FontSize="12"
                       TextColor="Gray"/>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
