    <Description>Motor DSL para impresoras térmicas ESC/POS — DI y fluent API (AddMotorDslEngine)</Description>
    <PackageTags>escpos;thermal;printer;dsl;dotnet;extensions;di</PackageTags>
    <PackageProjectUrl>https://github.com/UTN-FRP-TUP-Aplicada-2025/Ejemplos_Maui_PrintThermal_Driver</PackageProjectUrl>
    <RepositoryUrl>https://github.com/UTN-FRP-TUP-Aplicada-2025/Ejemplos_Maui_PrintThermal_Driver</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
